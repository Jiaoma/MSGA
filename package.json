{
  "name": "msga",
  "version": "1.0.0",
  "description": "Make Small language models Great Again - AI coding agent optimized for SLM",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "msga": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "test": "vitest --exclude benchmarks/fixtures/** --exclude .msga-bench/**",
    "lint": "biome check src/ benchmarks/*.ts benchmarks/runners/ tests/benchmark-*.test.ts tests/patch-model.test.ts",
    "bench": "tsx benchmarks/compare.ts",
    "bench:qwen": "tsx benchmarks/compare.ts --model qwen3:8b",
    "bench:weak": "tsx benchmarks/compare.ts --model phi4-mini:3.8b"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "chalk": "^5.3.0",
    "commander": "^13.0.0",
    "glob": "^10.3.0",
    "ink": "^5.0.0",
    "openai": "^4.70.0",
    "ora": "^8.0.0",
    "react": "^18.3.0",
    "tree-sitter": "^0.22.4",
    "tree-sitter-python": "^0.23.6",
    "tree-sitter-typescript": "^0.23.2",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
